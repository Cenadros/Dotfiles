#!/usr/bin/env zsh

# GIT ALIASES

# Get the default branch name (main/master)
gdefault() { git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main"; }

alias gversion="git rev-parse --short HEAD"
alias gbranch="git rev-parse --abbrev-ref HEAD"

gpull() { git checkout "$(gdefault)" && git pull && git checkout development && git pull; }
gpullLoopBack() { local branch; branch=$(gbranch); gpull && git checkout "$branch"; }
gitPullProd() { local branch; branch=$(git branch --show-current); gpull && git checkout "$branch" && git pull; }
gpublishAll() { git checkout development && git pull && git push && git checkout "$(gdefault)" && git pull && git push; }
fetchToClean() { git fetch -p && git checkout "$(gdefault)" && git pull && git branch -r --merged | grep -v "\*\|$(gdefault)\|release\|development" | sed 's/origin\///' > merged_branches.txt; }

alias cleanBranches="cat merged_branches.txt | xargs -n 1 git push --delete origin && rm -rf merged_branches.txt"
alias gbr='for k in `git branch -r | perl -pe "s/^..(.*?)( ->.*)?$/\1/"`; do echo -e `git show --pretty=format:"%Cgreen%ci %Cblue%cr%Creset" $k -- | head -n 1`\\t$k; done | sort -r'
alias t='git for-each-ref --format="%(color:green)%(refname:short) %(color:red)%(taggerdate:relative)" --sort="taggerdate" refs/tags'

# DOCKER
alias dup='ddown && make'
alias ddown='containers=$(docker ps -a -q 2>/dev/null); if [ -n "$containers" ]; then echo "stopping docker containers..." && docker stop "$containers" > /dev/null && echo "docker containers stopped."; else echo "no docker containers running."; fi'

# DOTFILES
alias dot_update='bash ~/.dotfiles/scripts/update'
