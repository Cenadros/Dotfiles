#!/bin/bash
set -e

export DOTFILES_PATH="$HOME/.dotfiles"

cd "$(dirname "${BASH_SOURCE[0]}")" \
    && . "utils.bash"

OS="$(get_os)"

echo ""
echo "🖥  Detected: $(get_os_name) ($(get_arch))"
echo "-------------------------------------------------"
echo ""

# ===========================================================================
# WSL configuration (only on WSL)
# ===========================================================================

if is_wsl; then
    echo "👉  Copying wsl.conf file"
    sudo cp "$DOTFILES_PATH/wsl.conf" /etc/wsl.conf
fi

# ===========================================================================
# Homebrew (install early — needed by later steps on macOS)
# ===========================================================================

if ! cmd_exists brew; then
    echo "👉  Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Make brew available in the current session
BREW_PREFIX="$(get_brew_prefix)"
if [ -f "${BREW_PREFIX}/bin/brew" ]; then
    eval "$(${BREW_PREFIX}/bin/brew shellenv)"
fi

# ===========================================================================
# Default shell → zsh
# ===========================================================================

echo "👉  Changing default terminal to zsh"
ZSH_PATH="$(command -v zsh)"
if [ -n "$ZSH_PATH" ] && [ "$SHELL" != "$ZSH_PATH" ]; then
    # Ensure zsh is listed in /etc/shells (required by chsh)
    if ! grep -qx "$ZSH_PATH" /etc/shells 2>/dev/null; then
        echo "$ZSH_PATH" | sudo tee -a /etc/shells > /dev/null 2>&1 || true
    fi
    chsh -s "$ZSH_PATH" < /dev/null > /dev/null 2>&1 || {
        print_warning "Could not change shell automatically. Run: chsh -s $ZSH_PATH"
    }
fi

# ===========================================================================
# Docker / Container runtime
# ===========================================================================

install_docker_linux() {
    local distro
    distro="$(get_os)"

    case "$distro" in
        debian)
            pkg_update

            pkg_install ca-certificates curl gnupg lsb-release

            sudo install -m 0755 -d /etc/apt/keyrings
            if [ ! -f /etc/apt/keyrings/docker.asc ]; then
                curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
                    sudo tee /etc/apt/keyrings/docker.asc > /dev/null
                sudo chmod a+r /etc/apt/keyrings/docker.asc
            fi

            # Determine the correct Docker repo URL based on distro
            local docker_distro="ubuntu"
            if [ -f /etc/os-release ]; then
                . /etc/os-release
                case "$ID" in
                    debian) docker_distro="debian" ;;
                    *)      docker_distro="ubuntu" ;;
                esac
            fi

            echo \
              "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/${docker_distro} \
              $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | \
              sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

            pkg_update
            pkg_install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
            ;;

        fedora)
            sudo dnf -y install dnf-plugins-core > /dev/null
            sudo dnf config-manager --add-repo https://download.docker.com/linux/fedora/docker-ce.repo 2>/dev/null || true
            pkg_install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
            sudo systemctl start docker 2>/dev/null || true
            sudo systemctl enable docker 2>/dev/null || true
            ;;

        arch)
            pkg_install docker docker-compose docker-buildx
            sudo systemctl start docker 2>/dev/null || true
            sudo systemctl enable docker 2>/dev/null || true
            ;;

        suse)
            sudo zypper install -y docker docker-compose > /dev/null
            sudo systemctl start docker 2>/dev/null || true
            sudo systemctl enable docker 2>/dev/null || true
            ;;

        *)
            print_warning "Unknown Linux distro. Install Docker manually: https://docs.docker.com/engine/install/"
            return
            ;;
    esac

    # Add user to docker group
    if ! groups "$USER" | grep -q docker; then
        sudo groupadd docker 2>/dev/null || true
        sudo usermod -aG docker "$USER"
        print_warning "Added $USER to docker group. Log out/in for this to take effect."
    fi
}

install_docker_macos() {
    echo ""
    echo "    Choose your container runtime:"
    echo ""
    echo "    1) OrbStack  (lightweight, fast, recommended)"
    echo "    2) Docker Desktop"
    echo "    3) Skip"
    echo ""
    read -r -p "    Your choice [1/2/3]: " docker_choice

    case "$docker_choice" in
        1)
            echo "👉  Installing OrbStack..."
            if cmd_exists brew; then
                brew install --cask orbstack
            else
                print_error "Homebrew is required to install OrbStack."
                echo "    Install manually from: https://orbstack.dev"
            fi
            ;;
        2)
            echo "👉  Installing Docker Desktop..."
            if cmd_exists brew; then
                brew install --cask docker
            else
                print_error "Homebrew is required to install Docker Desktop."
                echo "    Install manually from: https://www.docker.com/products/docker-desktop/"
            fi
            ;;
        3)
            echo "    Skipping container runtime installation."
            ;;
        *)
            echo "    Invalid choice. Skipping container runtime installation."
            ;;
    esac
}

echo "👉  Installing container runtime"
if is_wsl && cmd_exists winget.exe; then
    echo "    Installing Docker Desktop via winget..."
    winget.exe install -e --id Docker.DockerDesktop --accept-source-agreements --accept-package-agreements || true
else
    case "$OS" in
        debian|fedora|arch|suse|linux)
            install_docker_linux
            ;;
        macos)
            install_docker_macos
            ;;
        *)
            print_warning "Please install Docker manually: https://docs.docker.com/desktop/"
            echo -n "    Would you like to proceed with the next steps? (y/n) "
            read -r reply
            if [ "$reply" = n ] || [ "$reply" = N ]; then
                exit
            fi
            ;;
    esac
fi

# ===========================================================================
# Prezto (zsh framework)
# ===========================================================================

echo "👉  Cloning prezto into: ${HOME}/.zprezto"
git clone --recursive https://github.com/sorin-ionescu/prezto.git "${HOME}/.zprezto" 2> /dev/null || \
    git -C "${HOME}/.zprezto" pull

echo "👉  Cloning prezto-contrib into: ${HOME}/.zprezto/contrib"
git clone --recurse-submodules https://github.com/belak/prezto-contrib "${HOME}/.zprezto/contrib" 2> /dev/null || \
    git -C "${HOME}/.zprezto/contrib" pull

# ===========================================================================
# NVM (Node Version Manager)
# ===========================================================================

echo "👉  Cloning nvm into: ${HOME}/.nvm"
git clone https://github.com/nvm-sh/nvm.git "${HOME}/.nvm" 2> /dev/null || true

echo "👉  Checking nvm latest version"
pushd "${HOME}/.nvm" > /dev/null
    git fetch --tags origin
    git checkout "$(git describe --abbrev=0 --tags --match "v[0-9]*" "$(git rev-list --tags --max-count=1)")"
popd > /dev/null

# ===========================================================================
# Build tools
# ===========================================================================

echo "👉  Installing build tools"
case "$OS" in
    debian)
        pkg_install build-essential make
        ;;
    fedora)
        sudo dnf groupinstall -y "Development Tools" > /dev/null 2>&1 || true
        pkg_install make
        ;;
    arch)
        pkg_install base-devel make
        ;;
    suse)
        sudo zypper install -y -t pattern devel_basis > /dev/null 2>&1 || true
        pkg_install make
        ;;
    macos)
        # Xcode CLI tools already provide build essentials
        ;;
esac

# ===========================================================================
# mkcert (local HTTPS certificates)
# ===========================================================================

echo "👉  Installing mkcert"
if cmd_exists brew; then
    brew install mkcert 2>/dev/null || true
else
    pkg_install mkcert 2>/dev/null || print_warning "Could not install mkcert automatically."
fi

if cmd_exists mkcert; then
    echo "👉  Generating mkcert certificates"
    mkcert -install 2>/dev/null || true
fi

# ===========================================================================
# AI coding tools
# ===========================================================================

echo "👉  Installing AI coding tools"

# Claude Desktop
if is_wsl && cmd_exists winget.exe; then
    echo "    Installing Claude Desktop via winget..."
    winget.exe install -e --id Anthropic.Claude --accept-source-agreements --accept-package-agreements || true
elif [ "$OS" = "macos" ]; then
    if [ ! -d "/Applications/Claude.app" ]; then
        echo "    Installing Claude Desktop..."
        brew install --cask claude
    else
        echo "    Claude Desktop already installed."
    fi
else
    print_warning "Claude Desktop is only available on macOS/Windows. Download manually if a Linux build becomes available."
fi

# Claude CLI (Claude Code)
if ! cmd_exists claude; then
    echo "    Installing Claude CLI..."
    if [ "$OS" = "macos" ]; then
        brew install --cask claude-code
    else
        curl -fsSL https://claude.ai/install.sh | bash
    fi
else
    echo "    Claude CLI already installed."
fi

# Codex Desktop
if [ "$OS" = "macos" ]; then
    if [ ! -d "/Applications/Codex.app" ]; then
        echo "    Installing Codex Desktop..."
        if [ "$(get_arch)" = "arm64" ]; then
            brew install --cask codex-app
        else
            curl -fsSL -o /tmp/Codex.dmg "https://persistent.oaistatic.com/codex-app-prod/Codex.dmg"
            hdiutil attach /tmp/Codex.dmg -nobrowse -quiet
            cp -R "/Volumes/Codex Installer/Codex.app" /Applications/
            hdiutil detach "/Volumes/Codex Installer" -quiet
            rm -f /tmp/Codex.dmg
        fi
    else
        echo "    Codex Desktop already installed."
    fi
else
    print_warning "Codex Desktop is only available on macOS."
fi

# Codex CLI
if ! cmd_exists codex; then
    echo "    Installing Codex CLI..."
    if [ "$OS" = "macos" ]; then
        brew install --cask codex
    elif cmd_exists npm; then
        npm install -g @openai/codex
    else
        print_warning "npm not found. Install Node.js first, then run: npm install -g @openai/codex"
    fi
else
    echo "    Codex CLI already installed."
fi

# OpenCode CLI
if ! cmd_exists opencode; then
    echo "    Installing OpenCode CLI..."
    if cmd_exists brew; then
        brew install opencode
    else
        curl -fsSL https://opencode.ai/install | bash
    fi
else
    echo "    OpenCode CLI already installed."
fi

# OpenCode Desktop
if [ "$OS" = "macos" ]; then
    if [ ! -d "/Applications/OpenCode Desktop.app" ]; then
        echo "    Installing OpenCode Desktop..."
        brew install --cask opencode-desktop
    else
        echo "    OpenCode Desktop already installed."
    fi
else
    print_warning "Install OpenCode Desktop manually from https://opencode.ai/download"
fi

# ===========================================================================
# AI tools — plugins & skills
# ===========================================================================

echo "👉  Installing AI tool plugins and skills"

# GSD (Get Stuff Done) — spec-driven development & context engineering
if cmd_exists npx; then
    echo "    Installing GSD..."
    npx -y get-shit-done-cc@latest --all --global 2>/dev/null || true
else
    print_warning "npx not found. Skipping GSD. Install Node.js, then run: npx get-shit-done-cc@latest --all --global"
fi

# Claude Code — MCP servers & plugins
if cmd_exists claude; then
    echo "    Adding Claude Code MCP servers..."
    claude mcp add context7 --scope user -- npx -y @upstash/context7-mcp@latest 2>/dev/null || true
    claude mcp add sequential-thinking --scope user -- npx -y @modelcontextprotocol/server-sequential-thinking 2>/dev/null || true
    claude mcp add playwright --scope user -- npx -y @playwright/mcp@latest 2>/dev/null || true

    echo "    Setting up Claude Code plugin marketplaces..."
    if claude plugin marketplace add anthropics/claude-code 2>/dev/null; then
        claude plugin marketplace add obra/superpowers-marketplace 2>/dev/null || true
        claude plugin marketplace add ComposioHQ/awesome-claude-plugins 2>/dev/null || true
        claude plugin marketplace add trailofbits/skills 2>/dev/null || true

        echo "    Installing Claude Code plugins..."
        claude plugin install commit-commands@claude-code-plugins 2>/dev/null || true
        claude plugin install code-review@claude-code-plugins 2>/dev/null || true
        claude plugin install frontend-design@claude-code-plugins 2>/dev/null || true
        claude plugin install feature-dev@claude-code-plugins 2>/dev/null || true
        claude plugin install superpowers@superpowers-marketplace 2>/dev/null || true
    else
        print_warning "Claude Code plugin CLI not available. Run inside Claude Code:"
        echo "      /plugin marketplace add anthropics/claude-code"
        echo "      /plugin marketplace add obra/superpowers-marketplace"
        echo "      /plugin marketplace add ComposioHQ/awesome-claude-plugins"
        echo "      /plugin marketplace add trailofbits/skills"
        echo "      /plugin install commit-commands@claude-code-plugins"
        echo "      /plugin install code-review@claude-code-plugins"
        echo "      /plugin install frontend-design@claude-code-plugins"
        echo "      /plugin install feature-dev@claude-code-plugins"
        echo "      /plugin install superpowers@superpowers-marketplace"
    fi

    # Ensure plugins are enabled directly in settings.json (fallback for
    # when the CLI plugin commands are not yet available)
    CLAUDE_SETTINGS="${HOME}/.claude/settings.json"
    mkdir -p "${HOME}/.claude"
    if cmd_exists jq; then
        if [ -f "$CLAUDE_SETTINGS" ]; then
            tmp="$(mktemp)"
            jq '.enabledPlugins = ((.enabledPlugins // {}) + {
                "commit-commands@claude-code-plugins": true,
                "code-review@claude-code-plugins": true,
                "frontend-design@claude-code-plugins": true,
                "feature-dev@claude-code-plugins": true,
                "superpowers@superpowers-marketplace": true
            })' "$CLAUDE_SETTINGS" > "$tmp" && mv "$tmp" "$CLAUDE_SETTINGS"
        else
            cat > "$CLAUDE_SETTINGS" <<'CLEOF'
{
  "enabledPlugins": {
    "commit-commands@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "superpowers@superpowers-marketplace": true
  }
}
CLEOF
        fi
        echo "    Claude Code plugins enabled in settings.json."
    else
        print_warning "jq not found. Add plugins manually to ~/.claude/settings.json"
    fi
fi

# OpenCode — plugins & skills
if cmd_exists opencode; then
    OPENCODE_GLOBAL="${HOME}/.config/opencode/opencode.json"
    mkdir -p "$(dirname "$OPENCODE_GLOBAL")"
    if [ ! -f "$OPENCODE_GLOBAL" ]; then
        echo "    Creating OpenCode global config with plugins..."
        cat > "$OPENCODE_GLOBAL" <<'OCEOF'
{
  "plugin": ["oh-my-opencode"]
}
OCEOF
    elif ! grep -q "oh-my-opencode" "$OPENCODE_GLOBAL" 2>/dev/null; then
        echo "    Adding oh-my-opencode to OpenCode config..."
        if cmd_exists jq; then
            tmp="$(mktemp)"
            jq '.plugin = ((.plugin // []) + ["oh-my-opencode"] | unique)' "$OPENCODE_GLOBAL" > "$tmp" && mv "$tmp" "$OPENCODE_GLOBAL"
        else
            print_warning "Add to your opencode.json: \"plugin\": [\"oh-my-opencode\"]"
        fi
    else
        echo "    OpenCode oh-my-opencode plugin already configured."
    fi
fi

# Superpowers skills — shared between Claude Code and OpenCode
echo "    Installing Superpowers skills..."
SUPERPOWERS_TMP="$(mktemp -d)"
if git clone --depth 1 https://github.com/obra/superpowers.git "$SUPERPOWERS_TMP" 2>/dev/null; then
    if cmd_exists claude && [ -d "$SUPERPOWERS_TMP/.claude/skills" ]; then
        mkdir -p "${HOME}/.claude/skills"
        cp -r "$SUPERPOWERS_TMP/.claude/skills/"* "${HOME}/.claude/skills/" 2>/dev/null || true
    fi
    if cmd_exists opencode && [ -d "$SUPERPOWERS_TMP/.opencode/skills" ]; then
        mkdir -p "${HOME}/.config/opencode/skills"
        cp -r "$SUPERPOWERS_TMP/.opencode/skills/"* "${HOME}/.config/opencode/skills/" 2>/dev/null || true
    fi
    rm -rf "$SUPERPOWERS_TMP"
else
    print_warning "Could not clone Superpowers repo. Install manually from https://github.com/obra/superpowers"
    rm -rf "$SUPERPOWERS_TMP"
fi

# ===========================================================================
# Terminal applications
# ===========================================================================

# Warp
echo "👉  Installing Warp terminal"
if ! cmd_exists warp-terminal && [ ! -d "/Applications/Warp.app" ]; then
    if is_wsl && cmd_exists winget.exe; then
        echo "    Installing Warp via winget..."
        winget.exe install -e --id Warp.Warp --accept-source-agreements --accept-package-agreements || true
    else
        case "$OS" in
            macos)
                brew install --cask warp
                ;;
            debian)
                curl -fsSL https://releases.warp.dev/linux/keys/warp.gpg | \
                    sudo gpg --dearmor -o /usr/share/keyrings/warp.gpg 2>/dev/null || true
                echo "deb [signed-by=/usr/share/keyrings/warp.gpg] https://releases.warp.dev/linux/deb stable main" | \
                    sudo tee /etc/apt/sources.list.d/warp.list > /dev/null
                pkg_update
                pkg_install warp-terminal
                ;;
            fedora)
                sudo rpm --import https://releases.warp.dev/linux/keys/warp.gpg 2>/dev/null || true
                printf '[warp]\nname=Warp Terminal\nbaseurl=https://releases.warp.dev/linux/rpm/stable\nenabled=1\ngpgcheck=1\ngpgkey=https://releases.warp.dev/linux/keys/warp.gpg\n' | \
                    sudo tee /etc/yum.repos.d/warp.repo > /dev/null
                pkg_install warp-terminal
                ;;
            arch)
                if cmd_exists yay; then
                    yay -S --noconfirm warp-terminal-bin
                else
                    print_warning "Install Warp from AUR: yay -S warp-terminal-bin"
                fi
                ;;
            *)
                print_warning "Warp is not available for this OS. Download manually from https://www.warp.dev"
                ;;
        esac
    fi
else
    echo "    Warp already installed."
fi

# Termius
echo "👉  Installing Termius"
if [ ! -d "/Applications/Termius.app" ] && ! cmd_exists termius && ! cmd_exists termius-app; then
    if is_wsl && cmd_exists winget.exe; then
        echo "    Installing Termius via winget..."
        winget.exe install -e --id Termius.Termius --accept-source-agreements --accept-package-agreements || true
    else
        case "$OS" in
            macos)
                brew install --cask termius
                ;;
            debian|fedora|arch|suse|linux)
                if cmd_exists snap; then
                    sudo snap install termius-app
                elif cmd_exists flatpak; then
                    flatpak install -y flathub com.termius.Termius
                else
                    print_warning "Install Termius manually from https://termius.com/linux"
                fi
                ;;
            *)
                print_warning "Termius is not available for this OS. Download manually from https://termius.com"
                ;;
        esac
    fi
else
    echo "    Termius already installed."
fi

# ===========================================================================
# Code editors
# ===========================================================================

# Visual Studio Code
echo "👉  Installing Visual Studio Code"
if ! cmd_exists code && [ ! -d "/Applications/Visual Studio Code.app" ]; then
    if is_wsl && cmd_exists winget.exe; then
        echo "    Installing Visual Studio Code via winget..."
        winget.exe install -e --id Microsoft.VisualStudioCode --accept-source-agreements --accept-package-agreements || true
    else
        case "$OS" in
            macos)
                brew install --cask visual-studio-code
                ;;
            debian)
                curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | \
                    sudo gpg --dearmor -o /usr/share/keyrings/packages.microsoft.gpg 2>/dev/null || true
                echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" | \
                    sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null
                pkg_update
                pkg_install code
                ;;
            fedora)
                sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc 2>/dev/null || true
                printf '[code]\nname=Visual Studio Code\nbaseurl=https://packages.microsoft.com/yumrepos/vscode\nenabled=1\ngpgcheck=1\ngpgkey=https://packages.microsoft.com/keys/microsoft.asc\n' | \
                    sudo tee /etc/yum.repos.d/vscode.repo > /dev/null
                pkg_install code
                ;;
            arch)
                if cmd_exists yay; then
                    yay -S --noconfirm visual-studio-code-bin
                elif cmd_exists snap; then
                    sudo snap install code --classic
                else
                    print_warning "Install VS Code from AUR: yay -S visual-studio-code-bin"
                fi
                ;;
            suse)
                sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc 2>/dev/null || true
                sudo zypper addrepo -g https://packages.microsoft.com/yumrepos/vscode vscode 2>/dev/null || true
                sudo zypper refresh > /dev/null 2>&1
                pkg_install code
                ;;
            linux)
                if cmd_exists snap; then
                    sudo snap install code --classic
                elif cmd_exists flatpak; then
                    flatpak install -y flathub com.visualstudio.code
                else
                    print_warning "Install VS Code manually from https://code.visualstudio.com"
                fi
                ;;
            *)
                print_warning "Install VS Code manually from https://code.visualstudio.com"
                ;;
        esac
    fi
else
    echo "    Visual Studio Code already installed."
fi

# ===========================================================================
# Git configuration
# ===========================================================================

echo "👉  Git config"
read -r -p "    Type in your email for gitconfig: " git_email
read -r -p "    Type in your name for gitconfig: " git_name

if [ -n "$git_email" ]; then
    sed_i "s/test@test.com/$git_email/g" "${DOTFILES_PATH}/dotfiles/.gitconfig"
fi
if [ -n "$git_name" ]; then
    sed_i "s/name = test$/name = $git_name/g" "${DOTFILES_PATH}/dotfiles/.gitconfig"
fi

# ===========================================================================
# Symlinks
# ===========================================================================

echo "👉  Symlinks"
bash "$DOTFILES_PATH/scripts/symlinks"

# ===========================================================================
# Done — reboot prompt (only useful on Linux / WSL)
# ===========================================================================

echo ""
echo "✅  Installation complete!"

if [ "$OS" != "macos" ]; then
    echo ""
    echo "👉  A system reboot is recommended to apply all changes."
    echo -n "    Would you like to reboot now? (y/n) "
    read -r reply

    if [ "$reply" = y ] || [ "$reply" = Y ]; then
        sudo reboot
    else
        echo "    Don't forget to restart your computer (or log out/in) manually."
    fi
else
    echo "    Open a new terminal window to start using your new configuration."
fi
